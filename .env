# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=asgamegsm

# CORS — comma separated origins of the frontend(s) allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Stripe — get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=sk_test_replace_me
# Optional: only required if you mount /api/webhook/stripe in your Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# Currency for Stripe Checkout (3-letter ISO code, lowercase). Default: pln
STORE_CURRENCY=pln

# --- BaseLinker (optional) ---
# Get token: BaseLinker → Account → My Account → API
# Inventory ID: Catalogs → your catalog (URL contains the id)
# Order source ID: Manage orders → Order sources → create one for the website
BASELINKER_TOKEN=
BASELINKER_INVENTORY_ID=
BASELINKER_ORDER_SOURCE_ID=
